# Environment configuration for Cosmos-H-Surgical-Simulator tutorial.
#
# Usage:
#   cp scripts/env.sh.template scripts/env.sh
#   # Edit env.sh and fill in all values
#   source scripts/env.sh
#
# IMPORTANT: env.sh is gitignored and must NEVER be committed — it contains
# API keys and machine-specific paths.

# ---------------------------------------------------------------------------
# HuggingFace
# ---------------------------------------------------------------------------
# Local cache directory for HuggingFace model weights and LeRobot datasets.
# Needs ~100 GB for Cosmos model weights + dataset.
export HF_HOME=/path/to/huggingface_cache

# ---------------------------------------------------------------------------
# Training
# ---------------------------------------------------------------------------
# Root directory where training checkpoints and artifacts are saved.
# Needs ~500 GB for a full training run (checkpoints saved every 200 steps).
export IMAGINAIRE_OUTPUT_ROOT=/path/to/training_output

# ---------------------------------------------------------------------------
# Weights & Biases — required for experiment tracking
# ---------------------------------------------------------------------------
# Create a free account at https://wandb.ai and copy your API key from
# https://wandb.ai/settings (Account > Danger Zone > API keys).
export WANDB_API_KEY=your_wandb_api_key_here

# ---------------------------------------------------------------------------
# Docker
# ---------------------------------------------------------------------------
# Tag of the Docker image built in step 1.5. Change only if you re-tagged it.
export COSMOS_CONTAINER_IMAGE=cosmos-predict2.5:local

# ---------------------------------------------------------------------------
# Paths
# ---------------------------------------------------------------------------
# Absolute path to the cloned Cosmos-H-Surgical-Simulator repository (step 1.3).
export COSMOS_CODE_PATH=/path/to/Cosmos-H-Surgical-Simulator

# Absolute path to the converted LeRobot dataset (step 2.3).
# The converter writes to $HF_HOME/lerobot/<repo-id> by default.
# Use the mini dataset path for quick iteration; swap for the full dataset
# path when ready for a production training run.
export SUTUREBOT_LEROBOT_PATH=${HF_HOME}/lerobot/suturebot_lerobot_mini

# Absolute path to the Cosmos-H-Surgical-Simulator DCP checkpoint directory
# downloaded in step 4 (points to iter_000023000/, not model/ inside it).
export COSMOS_H_CKPT_PATH=/path/to/checkpoints/checkpoints/iter_000023000

# Root directory where inference output videos are saved (step 5.3).
export SAVE_ROOT=/path/to/results/dvrk_eval
